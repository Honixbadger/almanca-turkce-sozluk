data/manual/auto_phrase_report.json
data/manual/ipa_checkpoint.json
data/manual/phrase_candidates_*.json
data/fetch_manifest.json
# Ham veri indirmeleri (tamamı — büyük dosyalar)
data/raw/
# Ek rapor dosyaları
output/*_report*.json
output/*_report*.md
output/*_fixes_*.json
output/*_review_*.json
output/*_suggestions_*.json
output/high_confidence_*.json

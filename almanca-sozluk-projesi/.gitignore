output/cleanup_*.json
output/deep_research_*.json
output/deep_research_*.csv
output/deep_research_*.jsonl
output/curated_deep_research_*.json
output/curated_deep_research_*.md
output/derivational_pairs_*.json
output/definition_availability.json
output/definition_enrichment_report.json
output/definition_quality_report_*.json
output/dictionary_quality_report*.json
output/duplicates_report.json
output/groq_quality_filter_report.json
output/dwds_verb_validation_report*.json
output/codex/

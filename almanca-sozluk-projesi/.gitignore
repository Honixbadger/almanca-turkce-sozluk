output/*_checkpoint*.json
output/baglamlar_checkpoint.json
output/groq_tr_checkpoint*.json
output/dewikt_*_checkpoint.json
output/dwds_syn_checkpoint.json
# Yedek dosyalar / Backup files
output/dictionary.backup-*.json
output/dictionary.jsonl.bak_*
output/dictionary.csv
# DWDS önbellek / DWDS cache
output/dwds_wp_cache/
